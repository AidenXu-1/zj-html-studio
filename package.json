{
  "name": "zj-html-studio",
  "version": "0.3.1",
  "private": true,
  "description": "Preview, search, inspect, and embed local HTML files with scoped resources and live reload.",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "lint": "eslint .",
    "release:check": "node scripts/check-release.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm test && npm run build && npm run release:check",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "html",
    "preview",
    "local-first"
  ],
  "author": "兆基",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AidenXu-1/zj-html-studio.git"
  },
  "bugs": {
    "url": "https://github.com/AidenXu-1/zj-html-studio/issues"
  },
  "homepage": "https://github.com/AidenXu-1/zj-html-studio#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "eslint-plugin-obsidianmd": "0.4.1",
    "globals": "17.7.0",
    "jiti": "2.7.0",
    "obsidian": "1.13.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
